{
	"info": {
		"_postman_id": "7815595c-cb27-4730-a397-ceaf022c4a90",
		"name": "todo-service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create new Todo Item",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"[POST /todos] should return 201 CREATED\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"const json = pm.response.json();\r",
							"\r",
							"pm.test(\"[POST /todos] response contains id\", function () {\r",
							"    pm.expect(json.id, \"Todo id must exist\").to.exist;\r",
							"});\r",
							"\r",
							"pm.test(\"[POST /todos] status is NOT_DONE by default\", function () {\r",
							"    pm.expect(json.status, \"New todo should be NOT_DONE\").to.eql(\"NOT_DONE\");\r",
							"});\r",
							"\r",
							"pm.test(\"[POST /todos] doneAt should be null\", function () {\r",
							"    pm.expect(json.doneAt, \"doneAt must be null for new todo\").to.be.null;\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"description\": \"Buy groceries\",\r\n  \"dueDate\": \"2030-04-10T18:00:00\"\r\n}\r\n",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8080/todos",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"todos"
					],
					"query": [
						{
							"key": "description",
							"value": "Buy+groceries",
							"disabled": true
						},
						{
							"key": "dueDate",
							"value": "2026-03-10T18:00:00",
							"disabled": true
						}
					]
				}
			},
			"response": []
		},
